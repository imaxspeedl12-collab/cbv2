local function waitForLoot()
    print("⏳ CHỜ NHẶT RƯƠNG...")
    local startTime = tick()
    local chestCollected = false
    
    -- LẤY GEM VÀ BELI HIỆN TẠI LÀM MỐC (CỐ ĐỊNH)
    local gemBefore = game.Players.LocalPlayer.PlayerStats.Gem.Value
    local beliBefore = game.Players.LocalPlayer.PlayerStats.beli.Value
    print(string.format("📊 GEM TRƯỚC KHI NHẶT: %d | BELI: %d", gemBefore, beliBefore))
    
    -- CHỜ TỐI ĐA 15 GIÂY (TĂNG LÊN VÌ RƯƠNG CÓ THỂ XUẤT HIỆN CHẬM)
    while (tick() - startTime) < 7 and not chestCollected and getgenv().SeaKinghop do
        local currentGem = game.Players.LocalPlayer.PlayerStats.Gem.Value
        local currentBeli = game.Players.LocalPlayer.PlayerStats.beli.Value
        
        -- KIỂM TRA GEM HOẶC BELI TĂNG (SO VỚI GIÁ TRỊ BAN ĐẦU)
        if currentGem > gemBefore or currentBeli > beliBefore then
            chestCollected = true
            print(string.format("✅ NHẶT RƯƠNG THÀNH CÔNG! Gem: %d → %d (tăng %d)", 
                  gemBefore, currentGem, currentGem - gemBefore))
            if currentBeli > beliBefore then
                print(string.format("💰 Beli: %d → %d (tăng %d)", 
                      beliBefore, currentBeli, currentBeli - beliBefore))
            end
            -- CẬP NHẬT startGem VÀ startBeli
            startGem = currentGem
            startBeli = currentBeli
            saveCollectedServer(game.JobId)  -- LƯU SERVER ĐÃ ĂN RƯƠNG
                saveCollectedServer(game.JobId)
    		    break
        end
        
        -- KIỂM TRA RƯƠNG CÒN KHÔNG (NẾU HẾT THÌ THOÁT)
        if not hasAnyChest() and (tick() - startTime) > 5 then
            print("⚠️ RƯƠNG ĐÃ BIẾN MẤT!")
            break
        end
        
        -- IN LOG MỖI 3 GIÂY ĐỂ BIẾT ĐANG CHỜ
        if math.floor(tick() - startTime) % 3 == 0 and (tick() - startTime) > 1 then
            print(string.format("⏳ ĐANG CHỜ... Đã qua %.0f giây | Gem hiện tại: %d", 
                  tick() - startTime, currentGem))
        end
        
        task.wait(1)  -- KIỂM TRA MỖI 1 GIÂY (THAY VÌ 2 GIÂY)
    end
    
    if not chestCollected then
        print("⚠️ HẾT 7 GIÂY KHÔNG NHẶT ĐƯỢC RƯƠNG!")
    end
    
 -- 👈 THÊM DÒNG NÀY: RESET GEM GỐC SAU KHI NHẶT XONG
    startGem = nil
    startBeli = nil

    return chestCollected
end

