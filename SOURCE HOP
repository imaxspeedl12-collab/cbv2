    if uptime >= 4 * 60 * 60 + 19 * 60 + 30 and uptime <= 4 * 60 * 60 + 26 * 60 then
        return "Group1 - 4h19:30-4h26"
    elseif uptime >= 8 * 60 * 60 + 50 * 60 + 30 and uptime <= 8 * 60 * 60 + 57 * 60 then
        return "Group2 - 8h50:30-8h57"
    elseif uptime >= 59 * 60 - 90 and uptime <= 1 * 60 * 60 + 4 * 60 then
        return "Group3 - 0h57:30-1h04"
