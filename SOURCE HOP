local function saveCollectedServer(jobId)
        if not collectedServers[jobId] then
                collectedServers[jobId] = os.time()
        local list = {}
        for id, t in pairs(collectedServers) do
            table.insert(list, id .. "|" .. t)
        end
        local content = table.concat(list, "\n")
                writefile(collectedFile, content)
            else
      end
end

local function removeExpiredServers()
    local now = os.time()
    local removed = false
    for id, t in pairs(collectedServers) do
        if now - t > 3480 then
            collectedServers[id] = nil
            removed = true
        end
    end
    if removed then
        local list = {}
        for id, t in pairs(collectedServers) do
            table.insert(list, id .. "|" .. t)
        end
        writefile(collectedFile, table.concat(list, "\n"))
        print(string.format("🗑️ Đã xóa server cũ (quá 1 tiếng), còn %d server trong danh sách", table.getn(list)))
    end
end

