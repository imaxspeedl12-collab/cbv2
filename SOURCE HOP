-- ===== HÀM ĐÁNH BOSS =====
local function fightBossByType(bossType)
    print(string.format("⚔️ ĐANG ĐÁNH %s...", bossType))
    
    local bossDead = false
    while not bossDead and getgenv().SeaKinghop do
        task.wait(8)
        
        local checkSeaKing = Workspace.SeaMonster:FindFirstChild("SeaKing")
        local checkHydra = Workspace.SeaMonster:FindFirstChild("HydraSeaKing")
        
        local skHealthNow = checkSeaKing and checkSeaKing:FindFirstChild("Humanoid") and checkSeaKing.Humanoid.Health or 0
        local hydraHealthNow = checkHydra and checkHydra:FindFirstChild("Humanoid") and checkHydra.Humanoid.Health or 0
        
        if bossType == "SeaKing" and (not checkSeaKing or skHealthNow <= 0) then
            bossDead = true
            
        elseif bossType == "Hydra" and (not checkHydra or hydraHealthNow <= 0) then
            -- CHỜ 5 GIÂY ĐỂ HYDRA KỊP HỒI SINH
            print("⏳ HYDRA CÓ DẤU HIỆU CHẾT, CHỜ 5 GIÂY KIỂM TRA LẠI...")
            task.wait(5)
            
            local checkAgain = Workspace.SeaMonster:FindFirstChild("HydraSeaKing")
            local healthAgain = checkAgain and checkAgain:FindFirstChild("Humanoid") and checkAgain.Humanoid.Health or 0
            
            if not checkAgain or healthAgain <= 0 then
                bossDead = true
                print("💀 HYDRA ĐÃ CHẾT THẬT!")
            else
                print("🔄 HYDRA HỒI SINH, TIẾP TỤC ĐÁNH...")
            end
            
        elseif bossType == "SeaKing/Hydra" and 
               (not checkSeaKing or skHealthNow <= 0) and (not checkHydra or hydraHealthNow <= 0) then
            bossDead = true
        end
    end
    
    print(string.format("💀 %s ĐÃ CHẾT!", bossType))
end

-- ===== HÀM CHỜ BOSS SPAWN =====
local function waitForBossSpawn(bossType, timeout)
    timeout = timeout or 7
    print(string.format("⏳ CHỜ %s SPAWN...", bossType))
    local waitCount = 0
    
    while waitCount < timeout and getgenv().SeaKinghop do
        task.wait(1)
        waitCount = waitCount + 1
        
        local checkSeaKing = Workspace.SeaMonster:FindFirstChild("SeaKing")
        local checkHydra = Workspace.SeaMonster:FindFirstChild("HydraSeaKing")
        
        if bossType == "SeaKing" and checkSeaKing and checkSeaKing:FindFirstChild("Humanoid") and checkSeaKing.Humanoid.Health > 0 then
            print("🔥 SEAKING ĐÃ SPAWN!")
            return true
        elseif bossType == "Hydra" and checkHydra and checkHydra:FindFirstChild("Humanoid") and checkHydra.Humanoid.Health > 0 then
            print("🔥 HYDRA ĐÃ SPAWN!")
            return true
        elseif (bossType == "SeaKing/Hydra") and 
               ((checkSeaKing and checkSeaKing:FindFirstChild("Humanoid") and checkSeaKing.Humanoid.Health > 0) or
                (checkHydra and checkHydra:FindFirstChild("Humanoid") and checkHydra.Humanoid.Health > 0)) then
            print("🔥 SEAKING/HYDRA ĐÃ SPAWN!")
            return true
        end
    end
    
    print(string.format("⚠️ HẾT THỜI GIAN CHỜ %s SPAWN", bossType))
    return false
end

-- ===== HÀM XỬ LÝ TẤT CẢ BOSS ĐANG CÓ SẴN =====
local function processAllActiveBosses()
    local activeBosses = {}
    local Workspace = game:GetService("Workspace")
    
    local seaKing = Workspace.SeaMonster:FindFirstChild("SeaKing")
    local hydra = Workspace.SeaMonster:FindFirstChild("HydraSeaKing")
    
    local skHealth = seaKing and seaKing:FindFirstChild("Humanoid") and seaKing.Humanoid.Health or 0
    local hydraHealth = hydra and hydra:FindFirstChild("Humanoid") and hydra.Humanoid.Health or 0
    
    if seaKing and skHealth > 0 then
        table.insert(activeBosses, {type = "SeaKing", obj = seaKing, health = skHealth})
        print("🎯 PHÁT HIỆN SEAKING ĐANG CÓ")
    end
    if hydra and hydraHealth > 0 then
        table.insert(activeBosses, {type = "Hydra", obj = hydra, health = hydraHealth})
        print("🎯 PHÁT HIỆN HYDRA ĐANG CÓ")
    end
    
    if #activeBosses == 0 then
        return 0
    end
    
    print(string.format("📋 TỔNG CỘNG PHÁT HIỆN %d BOSS ĐANG CÓ", #activeBosses))
    
    for i, boss in ipairs(activeBosses) do
        print(string.format("⚔️ ĐANG XỬ LÝ %s (%d/%d)", boss.type, i, #activeBosses))
        fightBossByType(boss.type)
        print("📦 ĐỢI RƯƠNG XUẤT HIỆN...")
        task.wait(5)
        waitForLoot()
        
        if i < #activeBosses then
            print(string.format("🔄 TIẾP TỤC ĐÁNH %s", activeBosses[i+1].type))
        end
    end
    
    return #activeBosses
end

