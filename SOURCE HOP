local excludedFruits = {
    ["DoughFruit"] = true,
    ["GateFruit"] = true,
    ["DragonFruit"] = true,
    ["PhoenixFruit"] = true,
    ["ToyFruit"] = true,
    ["OpFruit"] = true,
